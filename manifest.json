{
    "content_scripts": [ {
       "js": [ "template-loader.js", "score-component.js", "content.js" ],
       "matches": [ "https://act.hoyolab.com/app/zzz-game-record/index.html*" ],
       "run_at": "document_start"
    } ],
    "description": "戦績画面で追加ステータスを基準にスコア計算をする拡張",
    "manifest_version": 3,
    "name": "ゼンレスゾーンゼロスコア計算機",
    "short_name": "スコア計算機",
    "version": "1.0.0",
    "permissions": ["storage"],
    "icons": {
       "16": "Icons/Icon16.png",
       "32": "Icons/Icon32.png",
       "48": "Icons/Icon48.png",
       "128": "Icons/Icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": ["templates.html"],
            "matches": ["https://act.hoyolab.com/*"]
        }
    ]
 }
 